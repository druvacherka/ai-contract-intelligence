{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Processed Document Output",
  "description": "Schema for structured document output from the Data + OCR pipeline",
  "type": "object",
  "required": [
    "document_id",
    "filename",
    "pages",
    "document_type",
    "metadata",
    "clean_text",
    "text_preview",
    "processing_method"
  ],
  "properties": {
    "document_id": {
      "type": "string",
      "description": "Unique deterministic document identifier"
    },
    "filename": {
      "type": "string",
      "description": "Original document filename"
    },
    "pages": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of pages in the document"
    },
    "document_type": {
      "type": "string",
      "enum": [
        "contract",
        "amendment",
        "nda",
        "lease",
        "employment",
        "service_agreement",
        "license",
        "merger",
        "loan",
        "partnership",
        "unknown"
      ],
      "description": "Inferred document type"
    },
    "metadata": {
      "type": "object",
      "description": "Document metadata including processing info"
    },
    "clean_text": {
      "type": "string",
      "description": "Full cleaned document text"
    },
    "text_preview": {
      "type": "string",
      "description": "First 500 characters of clean text"
    },
    "processing_method": {
      "type": "string",
      "enum": ["native", "ocr", "pending"],
      "description": "Method used for text extraction"
    }
  }
}

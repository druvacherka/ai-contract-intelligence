# ===================================================
# Data + OCR Module — Environment Configuration
# ===================================================

# --- Tesseract OCR ---
# Path to Tesseract executable (Windows example shown)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Poppler ---
# Path to Poppler bin directory (Windows only, not needed on Linux/Mac)
POPPLER_PATH=C:\poppler\Library\bin

# --- Dataset Paths ---
CUAD_DATASET_PATH=datasets/raw
CUAD_OUTPUT_PATH=datasets/processed
EXPORT_PATH=datasets/exports

# --- Processing Settings ---
MAX_FILE_SIZE_MB=50
OCR_DPI=300
OCR_LANGUAGE=eng
BATCH_SIZE=10

# --- Logging ---
LOG_LEVEL=DEBUG
LOG_FILE=logs/pipeline.log
LOG_ROTATION=10 MB

# --- SpaCy Model ---
SPACY_MODEL=en_core_web_sm
